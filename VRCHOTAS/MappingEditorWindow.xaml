<Window x:Class="VRCHOTAS.MappingEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:VRCHOTAS.Converters"
        Title="Mapping Editor"
        Height="760"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Source Detection" FontWeight="Bold" />

        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="Use Re-detect to listen for a source input. Change a button state or move an axis quickly on the source device while detection is active." />

        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Detected Source:" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Text="{Binding SourceSummary}" />
            <Button Width="90" Margin="12,0,0,0" Content="Re-detect" Click="ClearDetectionClick" Visibility="{Binding HasDetectedSource, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <GroupBox Grid.Row="3" Grid.ColumnSpan="2" Header="Target" Margin="0,12,0,0" IsEnabled="{Binding CanEditTarget}">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Target:" />
                <ComboBox Grid.Row="0" Grid.Column="1" Width="300" HorizontalAlignment="Left" Margin="0,0,0,6"
                          ItemsSource="{Binding AvailableTargetKindOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Kind"
                          SelectedValue="{Binding SelectedTargetKind}" />

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Virtual Hand:" />
                <ComboBox Grid.Row="1" Grid.Column="1" Width="300" HorizontalAlignment="Left" Margin="0,0,0,6"
                          ItemsSource="{Binding HandTargets}" SelectedItem="{Binding TargetHand}" />

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="VR Axis Target:" Visibility="{Binding ShowAxisPicker, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ComboBox Grid.Row="2" Grid.Column="1" Width="300" HorizontalAlignment="Left"
                          Visibility="{Binding ShowAxisPicker, Converter={StaticResource BooleanToVisibilityConverter}}"
                           ItemsSource="{Binding AxisTargetOptions}" DisplayMemberPath="Label" SelectedValuePath="Target" SelectedValue="{Binding TargetAxis}" />

                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="VR Button Target:" Visibility="{Binding ShowButtonPicker, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ComboBox Grid.Row="3" Grid.Column="1" Width="300" HorizontalAlignment="Left"
                          Visibility="{Binding ShowButtonPicker, Converter={StaticResource BooleanToVisibilityConverter}}"
                           ItemsSource="{Binding ButtonTargetOptions}" DisplayMemberPath="Label" SelectedValuePath="Target" SelectedValue="{Binding TargetButton}" />

                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="Full Press Threshold:" Visibility="{Binding ShowFullPressThreshold, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Grid Grid.Row="4" Grid.Column="1" Visibility="{Binding ShowFullPressThreshold, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="0.0" Maximum="1.0" Value="{Binding FullPressThreshold}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding FullPressThreshold, StringFormat=F2}" VerticalAlignment="Center" />
                </Grid>

            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Grid.RowSpan="2" Grid.ColumnSpan="2" Header="Curves" Margin="0,10,0,0" Visibility="{Binding UsesAxisSource, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Invert:" />
                <CheckBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" IsChecked="{Binding Invert}" />

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Deadzone:" />
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="0.0" Maximum="0.8" Value="{Binding Deadzone}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding Deadzone, StringFormat=F2}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Curve:" />
                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="-1.0" Maximum="1.0" Value="{Binding Curve}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding Curve, StringFormat=F2}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Saturation:" />
                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="0.0" Maximum="5.0" Value="{Binding Saturation}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding Saturation, StringFormat=F2}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="4" VerticalAlignment="Top" Text="Curve Preview (x -> y):" />
                <Border Grid.Row="4" Grid.Column="1" Grid.RowSpan="2" BorderBrush="Gray" BorderThickness="1" Width="210" Height="210" HorizontalAlignment="Left">
                    <Canvas Width="200" Height="200" Margin="4">
                        <TextBlock Canvas.Left="2" Canvas.Top="2" Text="{Binding PlotYMaxLabel}" FontSize="10" Foreground="Gray" />
                        <TextBlock Canvas.Left="2" Canvas.Top="188" Text="{Binding PlotYMinLabel}" FontSize="10" Foreground="Gray" />
                        <Line X1="0" Y1="100" X2="200" Y2="100" Stroke="Gray" StrokeThickness="1" />
                        <Line X1="100" Y1="0" X2="100" Y2="200" Stroke="Gray" StrokeThickness="1" />
                        <Polyline Points="{Binding CurvePlotPoints}" Stroke="DeepSkyBlue" StrokeThickness="2" />

                        <Ellipse Width="12" Height="12" Fill="Red" Canvas.Left="{Binding CurrentInputPlotX}" Canvas.Top="{Binding CurrentInputPlotY}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="-6" Y="-6" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="6" Height="6" Fill="Yellow" Stroke="Black" StrokeThickness="0.6" Canvas.Left="{Binding CurrentOutputPlotX}" Canvas.Top="{Binding CurrentOutputPlotY}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="-3" Y="-3" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>
                </Border>

                <TextBlock Grid.Row="6" VerticalAlignment="Center" Text="Input / Mapped Output:" />
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Input:" />
                    <TextBlock Margin="6,0,12,0" Text="{Binding CurrentInputValue, StringFormat=F3}" />
                    <TextBlock Text="Mapped Output:" />
                    <TextBlock Margin="6,0,0,0" Text="{Binding CurrentOutputValue, StringFormat=F3}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="90" Margin="0,0,8,0" Content="Save" Click="SaveClick" />
            <Button Width="90" Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
