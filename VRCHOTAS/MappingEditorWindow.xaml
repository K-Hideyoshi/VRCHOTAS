<Window x:Class="VRCHOTAS.MappingEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:VRCHOTAS.Converters"
        Title="Mapping Editor"
        Height="760"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Source Detection" FontWeight="Bold" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Margin="0,3,12,0" Text="Auto detect is active. Change a button state or move an axis quickly on the source device." />
            <Button Width="90" Content="Clear" Click="ClearDetectionClick" />
        </StackPanel>

        <TextBlock Grid.Row="2" Margin="0,10,0,0" Text="Detected Source:" FontWeight="Bold" />
        <TextBlock Grid.Row="3" Margin="0,4,0,0" Text="{Binding SourceSummary}" />

        <GroupBox Grid.Row="4" Header="Target" Margin="0,12,0,0" IsEnabled="{Binding CanEditTarget}">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Target:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1" Width="300" Margin="10,0,0,6" HorizontalAlignment="Left"
                          ItemsSource="{Binding AvailableTargetKindOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Kind"
                          SelectedValue="{Binding SelectedTargetKind}" />

                <TextBlock Grid.Row="1" Text="Virtual Hand:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="1" Width="120" Margin="10,0,0,6" HorizontalAlignment="Left"
                          ItemsSource="{Binding HandTargets}" SelectedItem="{Binding TargetHand}" />

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Visibility="{Binding ShowAxisPicker, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="VR Axis Index:" VerticalAlignment="Center" />
                    <ComboBox Width="80" Margin="10,0,0,0" ItemsSource="{Binding AxisTargets}" SelectedItem="{Binding TargetAxisIndex}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Visibility="{Binding ShowButtonPicker, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="VR Button Index:" VerticalAlignment="Center" />
                    <ComboBox Width="80" Margin="10,0,0,0" ItemsSource="{Binding ButtonTargets}" SelectedItem="{Binding TargetButtonIndex}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="Curves" Margin="0,10,0,0" Visibility="{Binding UsesAxisSource, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <CheckBox Grid.Row="0" Content="Invert Input" IsChecked="{Binding Invert}" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Width="90" Text="Deadzone" VerticalAlignment="Center" />
                    <Slider Width="300" Minimum="0.0" Maximum="0.8" Value="{Binding Deadzone}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Width="50" Margin="10,0,0,0" Text="{Binding Deadzone, StringFormat=F2}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Width="90" Text="Curve" VerticalAlignment="Center" />
                    <Slider Width="300" Minimum="-1.0" Maximum="1.0" Value="{Binding Curve}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Width="50" Margin="10,0,0,0" Text="{Binding Curve, StringFormat=F2}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Width="90" Text="Saturation" VerticalAlignment="Center" />
                    <Slider Width="300" Minimum="0.0" Maximum="5.0" Value="{Binding Saturation}" TickFrequency="0.01" IsSnapToTickEnabled="False" />
                    <TextBlock Width="50" Margin="10,0,0,0" Text="{Binding Saturation, StringFormat=F2}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="4" Margin="0,8,0,4" Text="Curve Preview (x -> y)" FontWeight="Bold" />

                <Border Grid.Row="5" BorderBrush="Gray" BorderThickness="1" Width="210" Height="210" HorizontalAlignment="Left">
                    <Canvas Width="200" Height="200" Margin="4">
                        <TextBlock Canvas.Left="2" Canvas.Top="2" Text="{Binding PlotYMaxLabel}" FontSize="10" Foreground="Gray" />
                        <TextBlock Canvas.Left="2" Canvas.Top="188" Text="{Binding PlotYMinLabel}" FontSize="10" Foreground="Gray" />
                        <Line X1="0" Y1="100" X2="200" Y2="100" Stroke="Gray" StrokeThickness="1" />
                        <Line X1="100" Y1="0" X2="100" Y2="200" Stroke="Gray" StrokeThickness="1" />
                        <Polyline Points="{Binding CurvePlotPoints}" Stroke="DeepSkyBlue" StrokeThickness="2" />

                        <Ellipse Width="12" Height="12" Fill="Red" Canvas.Left="{Binding CurrentInputPlotX}" Canvas.Top="{Binding CurrentInputPlotY}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="-6" Y="-6" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="6" Height="6" Fill="Yellow" Stroke="Black" StrokeThickness="0.6" Canvas.Left="{Binding CurrentOutputPlotX}" Canvas.Top="{Binding CurrentOutputPlotY}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="-3" Y="-3" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>
                </Border>

                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Input:" />
                    <TextBlock Margin="6,0,12,0" Text="{Binding CurrentInputValue, StringFormat=F3}" />
                    <TextBlock Text="Mapped Output:" />
                    <TextBlock Margin="6,0,0,0" Text="{Binding CurrentOutputValue, StringFormat=F3}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="90" Margin="0,0,8,0" Content="Save" Click="SaveClick" />
            <Button Width="90" Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
