<Window x:Class="VRCHOTAS.HotkeysWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkeys"
        Width="580"
        Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Text="Click an input box to capture a shortcut. Release the key or joystick button to confirm. Use Clear before assigning again." />

        <TextBlock Grid.Row="1" Text="Cycle to previous configuration" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PreviousConfigBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Height="28"
                     GotFocus="OnPreviousBoxGotFocus"
                     LostFocus="OnCaptureBoxLostFocus"
                     PreviewKeyDown="OnCapturePreviewKeyDown"
                     PreviewKeyUp="OnPreviousBoxPreviewKeyUp" />
            <Button Grid.Column="1" Content="Clear" Width="64" Click="OnClearPreviousClick" />
        </Grid>

        <TextBlock Grid.Row="3" Text="Cycle to next configuration" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NextConfigBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Height="28"
                     GotFocus="OnNextBoxGotFocus"
                     LostFocus="OnCaptureBoxLostFocus"
                     PreviewKeyDown="OnCapturePreviewKeyDown"
                     PreviewKeyUp="OnNextBoxPreviewKeyUp" />
            <Button Grid.Column="1" Content="Clear" Width="64" Click="OnClearNextClick" />
        </Grid>

        <TextBlock Grid.Row="5" Text="Toggle Master Switch (mapping on/off)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MasterSwitchBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Height="28"
                     GotFocus="OnMasterBoxGotFocus"
                     LostFocus="OnCaptureBoxLostFocus"
                     PreviewKeyDown="OnCapturePreviewKeyDown"
                     PreviewKeyUp="OnMasterBoxPreviewKeyUp" />
            <Button Grid.Column="1" Content="Clear" Width="64" Click="OnClearMasterClick" />
        </Grid>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="88" Margin="0,0,8,0" IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="88" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
