<Window x:Class="VRCHOTAS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:VRCHOTAS.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="760" Width="1280">
    <Window.Resources>
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
        <Style x:Key="MasterSwitchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#33000000" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Mapping">
                <MenuItem Header="Add Mapping" Command="{Binding OpenAddMappingDialogCommand}" />
                <MenuItem Header="Edit Selected Mapping" Command="{Binding OpenEditMappingDialogCommand}" />
                <MenuItem Header="Delete Selected Mapping" Command="{Binding DeleteSelectedMappingCommand}" />
            </MenuItem>
            <MenuItem Header="Configuration">
                <MenuItem Header="Save" Command="{Binding SaveConfigCommand}" />
                <MenuItem Header="Save As..." Click="SaveAsConfigurationClick" />
                <Separator />
                <MenuItem Header="Refresh Configuration List" Command="{Binding RefreshConfigListCommand}" />

                <MenuItem Header="Load Configuration">
                    <MenuItem.ItemsSource>
                        <Binding Path="AvailableConfigurationFiles" />
                    </MenuItem.ItemsSource>
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.LoadConfigByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>

                <MenuItem Header="Set Default Configuration">
                    <MenuItem.ItemsSource>
                        <Binding Path="AvailableConfigurationFiles" />
                    </MenuItem.ItemsSource>
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.SetDefaultConfigByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Open Log Window" Command="{Binding OpenLogWindowCommand}" />
            </MenuItem>
            <MenuItem Header="Application">
                <MenuItem Header="Exit" Click="ExitApplicationClick" />
            </MenuItem>
        </Menu>

        <DockPanel Grid.Row="1" Margin="0,8,0,12" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="Master Switch:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" />
                <Button Style="{StaticResource MasterSwitchButtonStyle}"
                        Command="{Binding ToggleMappingEnabledCommand}"
                        Background="{Binding IsMappingEnabled, Converter={StaticResource BooleanToBrushConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Mapping" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MappingEnabledStatusText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock DockPanel.Dock="Left" Text="Discovered Device Status:" VerticalAlignment="Top" FontWeight="Bold" />
            <TextBlock DockPanel.Dock="Left" Text="{Binding DeviceStatusSummary}" Margin="8,0,16,0" VerticalAlignment="Top" TextWrapping="Wrap" />
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,12,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DeviceGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding DeviceId}" FontStyle="Italic" FontSize="11" Margin="0,0,0,6" />

                                    <TextBlock Text="Axes" FontWeight="Bold" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding Axes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="48" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                    <ProgressBar Grid.Column="1" Minimum="-1" Maximum="1" Value="{Binding Value}" Height="18" Margin="8,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat=F2}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Buttons" FontWeight="Bold" Margin="0,8,0,4" />
                                    <ItemsControl ItemsSource="{Binding Buttons}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4">
                                                    <Ellipse Width="12" Height="12" Fill="{Binding IsPressed, Converter={StaticResource BooleanToBrushConverter}}" Stroke="Black" />
                                                    <TextBlock Text="{Binding Name}" Margin="4,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding Mappings}"
                      SelectedItem="{Binding SelectedMapping}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="34">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="12"
                                         Height="12"
                                         Fill="{Binding IsSourceDeviceConnected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=RedGreen}"
                                         Stroke="Black"
                                         StrokeThickness="0.8"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Source Device" Binding="{Binding SourceDeviceName}" Width="*" />
                    <DataGridTextColumn Header="Source Button/Axis" Binding="{Binding SourceControlDisplay}" Width="140" />
                    <DataGridTextColumn Header="Target Hand" Binding="{Binding TargetHand}" Width="90" />
                    <DataGridTextColumn Header="Target Button/Axis" Binding="{Binding TargetControlDisplay}" Width="160" />
                    <DataGridTemplateColumn Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit" Width="55" Margin="0,0,6,0" Click="EditMappingClick" />
                                    <Button Content="Delete" Width="60" Click="DeleteMappingClick" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
