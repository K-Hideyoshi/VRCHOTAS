<Window x:Class="VRCHOTAS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:VRCHOTAS.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="760" Width="1280">
    <Window.Resources>
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
        <converters:MappingSourceIndicatorConverter x:Key="MappingSourceIndicatorConverter" />
        <Style x:Key="MasterSwitchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#33000000" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Configuration">
                <MenuItem Header="Save" Command="{Binding SaveConfigCommand}" />
                <MenuItem Header="Save As..." Click="SaveAsConfigurationClick" />
                <Separator />
                <MenuItem Header="Refresh Configuration List" Command="{Binding RefreshConfigListCommand}" />

                <MenuItem Header="Load Configuration">
                    <MenuItem.ItemsSource>
                        <Binding Path="ConfigurationMenuItems" />
                    </MenuItem.ItemsSource>
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding MenuHeader}" />
                            <Setter Property="Command" Value="{Binding DataContext.LoadConfigByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding FileName}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>

                <MenuItem Header="Set Default Configuration">
                    <MenuItem.ItemsSource>
                        <Binding Path="ConfigurationMenuItems" />
                    </MenuItem.ItemsSource>
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding MenuHeader}" />
                            <Setter Property="Command" Value="{Binding DataContext.SetDefaultConfigByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding FileName}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>

                <MenuItem Header="Preference">
                    <MenuItem Header="Hotkeys" Click="OnHotkeysMenuClick" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Open Log Window" Command="{Binding OpenLogWindowCommand}" />
            </MenuItem>
            <MenuItem Header="Application">
                <MenuItem Header="Exit" Click="ExitApplicationClick" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="0,8,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="Discovered Device:" VerticalAlignment="Top" FontWeight="Bold" />
                <TextBlock Text="{Binding DeviceStatusSummary}" Margin="8,0,16,0" VerticalAlignment="Top" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,24,0">
                <TextBlock Text="Driver heartbeat:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding DriverHeartbeatStatusDisplay}" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,24,0">
                <TextBlock Text="Refresh rate:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding JoystickRefreshRateDisplay}" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource MasterSwitchButtonStyle}"
                        Command="{Binding ToggleMappingEnabledCommand}"
                        Background="{Binding IsMappingEnabled, Converter={StaticResource BooleanToBrushConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Mapping" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MappingEnabledStatusText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,12,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DeviceGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding DeviceId}" FontStyle="Italic" FontSize="11" Margin="0,0,0,6" />

                                    <TextBlock Text="Axes" FontWeight="Bold" Margin="0,0,0,4" />
                                    <ItemsControl ItemsSource="{Binding Axes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="48" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                    <ProgressBar Grid.Column="1" Minimum="-1" Maximum="1" Value="{Binding Value}" Height="18" Margin="8,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat=F2}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Buttons" FontWeight="Bold" Margin="0,8,0,4" />
                                    <ItemsControl ItemsSource="{Binding Buttons}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4">
                                                    <Ellipse Width="12" Height="12" Fill="{Binding IsPressed, Converter={StaticResource BooleanToBrushConverter}}" Stroke="Black" />
                                                    <TextBlock Text="{Binding Name}" Margin="4,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Add Mapping" MinWidth="100" Margin="0,0,8,0" Command="{Binding OpenAddMappingDialogCommand}" />
                    <Button Content="Edit Selected" MinWidth="100" Margin="0,0,8,0" Command="{Binding OpenEditMappingDialogCommand}" />
                    <Button Content="Delete Selected" MinWidth="110" Command="{Binding DeleteSelectedMappingCommand}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Mappings}"
                          SelectedItem="{Binding SelectedMapping}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12"
                                             Height="12"
                                             Stroke="Black"
                                             StrokeThickness="0.8"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <MultiBinding Converter="{StaticResource MappingSourceIndicatorConverter}">
                                                <Binding Path="IsTemporarilyDisabled" />
                                                <Binding Path="IsSourceDeviceConnected" />
                                            </MultiBinding>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Source Device" Binding="{Binding SourceDeviceName}" Width="*" />
                        <DataGridTextColumn Header="Source Button/Axis" Binding="{Binding SourceControlDisplay}" Width="140" />
                        <DataGridTextColumn Header="Target Hand" Binding="{Binding TargetHand}" Width="90" />
                        <DataGridTextColumn Header="Target Button/Axis" Binding="{Binding TargetControlDisplay}" Width="160" />
                        <DataGridTemplateColumn Header="Toggle" Width="64">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Toggle"
                                            Padding="6,2"
                                            Command="{Binding DataContext.ToggleMappingTempDisabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Edit" Width="55" Margin="0,0,6,0" Click="EditMappingClick" />
                                        <Button Content="Delete" Width="60" Click="DeleteMappingClick" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>
